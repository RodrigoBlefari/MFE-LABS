{
  "name": "mfe-ng-full",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "start": "npm run package && npm run serve",
    "start:dev": "ng serve mfe-ng-full --port 9400",
    "build": "ng build mfe-ng-full",
